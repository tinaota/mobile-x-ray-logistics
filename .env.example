# Copy this file to .env.local and fill in your values

# Auth — JWT signing secret (min 32 chars, change in production)
JWT_SECRET=your-secret-min-32-chars-change-in-production

# Per-role password overrides (optional — defaults work for demo)
# AUTH_DISPATCHER_PASSWORD=
# AUTH_TECHNICIAN_PASSWORD=
# AUTH_BILLING_PASSWORD=
# AUTH_CLIENT_PASSWORD=
# AUTH_ADMIN_PASSWORD=
# AUTH_COPILOT_PASSWORD=

# Twilio SMS — get from console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic Claude — powers the AI Co-Pilot (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Supabase — get from supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Service role key — server-side only, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mapbox — get from account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=
